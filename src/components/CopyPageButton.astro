---
interface Props {
  pageUrl: string;
  markdownUrl: string;
}

const { pageUrl, markdownUrl } = Astro.props;

const prompt = `Read this page and answer my questions about it: ${pageUrl}`;
const encoded = encodeURIComponent(prompt);
const chatGptUrl = `https://chatgpt.com/?q=${encoded}`;
const claudeUrl = `https://claude.ai/new?q=${encoded}`;
const perplexityUrl = `https://www.perplexity.ai/?q=${encoded}`;
---

<div class="copy-page" data-copy-page>
  <button
    type="button"
    class="copy-page-button"
    aria-haspopup="true"
    aria-expanded="false"
    aria-controls="copy-page-panel"
  >
    <svg
      class="copy-page-icon"
      viewBox="0 0 16 16"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <rect x="5" y="5" width="9" height="9" rx="1.5"></rect>
      <path d="M11 5V3.5A1.5 1.5 0 0 0 9.5 2h-6A1.5 1.5 0 0 0 2 3.5v6A1.5 1.5 0 0 0 3.5 11H5"></path>
    </svg>
    <span>Copy page</span>
    <svg
      class="copy-page-chevron"
      viewBox="0 0 14 14"
      fill="none"
      stroke="currentColor"
      stroke-width="1.75"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <polyline points="3 5 7 9 11 5"></polyline>
    </svg>
  </button>

  <div class="copy-page-panel" id="copy-page-panel" role="menu">
    <button
      type="button"
      class="copy-page-item"
      role="menuitem"
      data-action="copy"
      data-markdown-url={markdownUrl}
    >
      <span class="copy-page-item-icon" aria-hidden="true">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="5" y="5" width="9" height="9" rx="1.5"></rect>
          <path d="M11 5V3.5A1.5 1.5 0 0 0 9.5 2h-6A1.5 1.5 0 0 0 2 3.5v6A1.5 1.5 0 0 0 3.5 11H5"></path>
        </svg>
      </span>
      <span class="copy-page-item-text">
        <span class="copy-page-item-title" data-default-label="Copy page">Copy page</span>
        <span class="copy-page-item-desc">Copy page as Markdown for LLMs</span>
      </span>
    </button>

    <a
      href={markdownUrl}
      target="_blank"
      rel="noopener"
      class="copy-page-item"
      role="menuitem"
    >
      <span class="copy-page-item-icon" aria-hidden="true">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="12" height="8" rx="1"></rect>
          <path d="M5 9V7l1.5 1L8 7v2"></path>
          <path d="M11 7v3"></path>
          <path d="M9.5 8.5L11 10l1.5-1.5"></path>
        </svg>
      </span>
      <span class="copy-page-item-text">
        <span class="copy-page-item-title">
          View as Markdown
          <svg class="copy-page-external" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 3h6v6"></path>
            <path d="M11 3l-7 7"></path>
          </svg>
        </span>
        <span class="copy-page-item-desc">View this page as plain text</span>
      </span>
    </a>

    <a href={chatGptUrl} target="_blank" rel="noopener" class="copy-page-item" role="menuitem">
      <span class="copy-page-item-icon" aria-hidden="true">
        <img src="/chat%20gpt%20logo.svg" alt="" />
      </span>
      <span class="copy-page-item-text">
        <span class="copy-page-item-title">
          Open in ChatGPT
          <svg class="copy-page-external" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 3h6v6"></path>
            <path d="M11 3l-7 7"></path>
          </svg>
        </span>
        <span class="copy-page-item-desc">Ask questions about this page</span>
      </span>
    </a>

    <a href={claudeUrl} target="_blank" rel="noopener" class="copy-page-item" role="menuitem">
      <span class="copy-page-item-icon" aria-hidden="true">
        <img src="/Claude_AI_symbol.svg" alt="" />
      </span>
      <span class="copy-page-item-text">
        <span class="copy-page-item-title">
          Open in Claude
          <svg class="copy-page-external" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 3h6v6"></path>
            <path d="M11 3l-7 7"></path>
          </svg>
        </span>
        <span class="copy-page-item-desc">Ask questions about this page</span>
      </span>
    </a>

    <a href={perplexityUrl} target="_blank" rel="noopener" class="copy-page-item" role="menuitem">
      <span class="copy-page-item-icon" aria-hidden="true">
        <img src="/perlexity-logo.svg" alt="" />
      </span>
      <span class="copy-page-item-text">
        <span class="copy-page-item-title">
          Open in Perplexity
          <svg class="copy-page-external" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 3h6v6"></path>
            <path d="M11 3l-7 7"></path>
          </svg>
        </span>
        <span class="copy-page-item-desc">Ask questions about this page</span>
      </span>
    </a>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('[data-copy-page]').forEach((wrapper) => {
    const button = wrapper.querySelector<HTMLButtonElement>('.copy-page-button');
    if (!button) return;

    const close = () => {
      wrapper.classList.remove('open');
      button.setAttribute('aria-expanded', 'false');
    };

    button.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = wrapper.classList.toggle('open');
      button.setAttribute('aria-expanded', String(open));
    });

    document.addEventListener('click', (e) => {
      if (!wrapper.contains(e.target as Node)) close();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });

    const copyButton = wrapper.querySelector<HTMLButtonElement>('[data-action="copy"]');
    const titleEl = copyButton?.querySelector<HTMLElement>('.copy-page-item-title');
    const defaultLabel = titleEl?.dataset.defaultLabel ?? 'Copy page';

    copyButton?.addEventListener('click', async (e) => {
      e.preventDefault();
      const url = copyButton.dataset.markdownUrl;
      if (!url || !titleEl) return;
      try {
        const res = await fetch(url);
        if (!res.ok) throw new Error(`Status ${res.status}`);
        const text = await res.text();
        await navigator.clipboard.writeText(text);
        titleEl.textContent = 'Copied!';
        setTimeout(() => {
          titleEl.textContent = defaultLabel;
        }, 1800);
      } catch (err) {
        console.error('Failed to copy markdown:', err);
        titleEl.textContent = 'Copy failed';
        setTimeout(() => {
          titleEl.textContent = defaultLabel;
        }, 1800);
      }
    });
  });
</script>
