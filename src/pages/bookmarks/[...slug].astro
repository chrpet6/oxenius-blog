---
import { getCollection, render } from 'astro:content';
import { marked } from 'marked';
import BookmarkLayout from '../../layouts/BookmarkLayout.astro';
import { fetchTranscript, fetchMetadata } from '../../lib/supadata';
import { summarizeTranscript } from '../../lib/anthropic';

export async function getStaticPaths() {
  const bookmarks = await getCollection('bookmarks', ({ data }) => !data.draft);
  return bookmarks.map((bookmark) => ({
    params: { slug: bookmark.id },
    props: { bookmark },
  }));
}

const { bookmark } = Astro.props;
const { Content } = await render(bookmark);

const metadata = await fetchMetadata(bookmark.data.href);

// Only invoke the auto-pipeline when the markdown body is essentially empty.
const hasManualBody = (bookmark.body ?? '').trim().length > 80;

let autoHtml: string | null = null;
if (!hasManualBody) {
  const transcript = await fetchTranscript(bookmark.data.href);
  if (transcript) {
    const autoMarkdown = await summarizeTranscript({
      href: bookmark.data.href,
      title: bookmark.data.title,
      source: bookmark.data.source,
      type: bookmark.data.type,
      transcript,
    });
    if (autoMarkdown) {
      autoHtml = await marked.parse(autoMarkdown);
    }
  }
}

const publishedDate = metadata?.createdAt
  ? new Date(metadata.createdAt)
  : bookmark.data.date;

const image = bookmark.data.image;
---

<BookmarkLayout
  title={bookmark.data.title}
  source={bookmark.data.source}
  type={bookmark.data.type}
  href={bookmark.data.href}
  date={publishedDate}
  image={image}
>
  {hasManualBody ? <Content /> : autoHtml ? <Fragment set:html={autoHtml} /> : <Content />}
</BookmarkLayout>
