---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';

type BookmarkType = 'Podcast' | 'YouTube' | 'Book' | 'Newsletter' | 'Essay' | 'Research';

const TYPE_ILLUSTRATIONS: Record<BookmarkType, string> = {
  Podcast: '/illustration-podcast-episode.png',
  YouTube: '/illustration-youtube-video.png',
  Book: '/illustration-book.png',
  Newsletter: '/illustration-essay.png',
  Essay: '/illustration-essay.png',
  Research: '/illustration-research-paper.png',
};

const SECTION_ORDER: BookmarkType[] = ['Podcast', 'YouTube', 'Book', 'Newsletter', 'Essay', 'Research'];

const SECTION_TITLES: Record<BookmarkType, string> = {
  Podcast: 'Podcasts',
  YouTube: 'YouTube channels',
  Book: 'Books',
  Newsletter: 'Newsletters',
  Essay: 'Essays',
  Research: 'Research papers',
};

const TYPE_ICONS: Record<BookmarkType, string> = {
  Podcast: 'tabler:microphone',
  YouTube: 'tabler:brand-youtube',
  Book: 'tabler:book-2',
  Newsletter: 'tabler:mail',
  Essay: 'tabler:file-text',
  Research: 'tabler:report-analytics',
};

const raw = await getCollection('bookmarks', ({ data }) => !data.draft);

const bookmarks = raw.map((b) => ({
  id: b.id,
  title: b.data.title,
  creator: b.data.creator,
  description: b.data.description,
  href: b.data.href,
  type: b.data.type as BookmarkType,
  image: b.data.image ?? TYPE_ILLUSTRATIONS[b.data.type as BookmarkType],
  order: b.data.order ?? 999,
}));

const grouped: Record<BookmarkType, typeof bookmarks> = {
  Podcast: [],
  YouTube: [],
  Book: [],
  Newsletter: [],
  Essay: [],
  Research: [],
};

for (const b of bookmarks) {
  grouped[b.type].push(b);
}

for (const type of SECTION_ORDER) {
  grouped[type].sort((a, b) => {
    if (a.order !== b.order) return a.order - b.order;
    return a.title.localeCompare(b.title);
  });
}
---

<BaseLayout
  title="Bookmarks — Christoffer Oxenius"
  description="The podcasts, YouTube channels, books, newsletters, essays, and research papers Christoffer follows."
  theme="light"
>
  <div class="home-shell">
    <section class="home-hero">
      <h1>Bookmarks</h1>
      <p>
        The podcasts, YouTube channels, books, newsletters, essays, and
        research papers I follow and recommend. Mostly B2B GTM, AI, and how
        software companies grow.
      </p>
    </section>

    <nav class="bookmark-tabs" aria-label="Jump to category">
      {SECTION_ORDER.map((type) => (
        grouped[type].length > 0 && (
          <a class="bookmark-tab" href={`#${type.toLowerCase()}`}>
            <Icon name={TYPE_ICONS[type]} class="bookmark-tab-icon" width={15} height={15} />
            {SECTION_TITLES[type]}
          </a>
        )
      ))}
    </nav>

    {SECTION_ORDER.map((type) => (
      grouped[type].length > 0 && (
        <section class="bookmark-section" id={type.toLowerCase()}>
          <h2 class="bookmark-section-title">
            <Icon name={TYPE_ICONS[type]} class="bookmark-section-icon" width={18} height={18} />
            {SECTION_TITLES[type]}
          </h2>
          <div class="home-grid">
            {grouped[type].map((b) => (
              <a class="grid-card grid-card--bookmark" href={b.href} target="_blank" rel="noopener">
                <div class="grid-card-image">
                  <img src={b.image} alt="" loading="lazy" />
                </div>
                <div class="grid-card-content">
                  <h3 class="grid-card-title">{b.title}</h3>
                  <p class="grid-card-description bookmark-card-creator">{b.creator}</p>
                  <p class="grid-card-description bookmark-card-why">{b.description}</p>
                </div>
              </a>
            ))}
          </div>
        </section>
      )
    ))}
  </div>
</BaseLayout>
