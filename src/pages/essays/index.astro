---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const essays = (await getCollection('essays', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const featured = essays[0];
const rest = essays.slice(1);
---

<BaseLayout title="Essays — Christoffer Oxenius" description="Essays about how AI is changing marketing, sales, and growth in B2B tech, and what founders and GTM leaders should do about it." theme="light">
  <div class="home-shell">
    <section class="home-hero">
      <h1>Essays</h1>
      <p>
        Essays about how AI is changing marketing, sales, and growth in B2B tech,
        and what founders and GTM leaders should do about it.
      </p>
    </section>

    {featured && (
      <a class="home-essay-card" href={`/essays/${featured.id}`}>
        {featured.data.heroImage && (
          <div class="home-essay-image">
            <img
              src={featured.data.heroImage}
              alt={featured.data.heroAlt ?? ''}
              loading="eager"
            />
            <span class="home-essay-badge home-essay-badge--overlay">
              {featured.data.category ?? 'Essay'}
            </span>
          </div>
        )}
        <div class="home-essay-content">
          <span class="home-essay-badge home-essay-badge--inline">
            {featured.data.category ?? 'Essay'}
          </span>
          <h2 class="home-essay-title">{featured.data.title}</h2>
          <p class="home-essay-description">{featured.data.description}</p>
          {featured.data.readTime && (
            <span class="home-essay-readtime">{featured.data.readTime}</span>
          )}
        </div>
      </a>
    )}

    {rest.length > 0 && (
      <section class="home-grid">
        {rest.map((essay) => (
          <a class="grid-card" href={`/essays/${essay.id}`}>
            {essay.data.heroImage && (
              <div class="grid-card-image">
                <img
                  src={essay.data.heroImage}
                  alt={essay.data.heroAlt ?? ''}
                  loading="lazy"
                />
                <span class="grid-card-badge">{essay.data.category ?? 'Essay'}</span>
              </div>
            )}
            <div class="grid-card-content">
              <h3 class="grid-card-title">{essay.data.title}</h3>
              <p class="grid-card-description">{essay.data.description}</p>
            </div>
          </a>
        ))}
      </section>
    )}
  </div>
</BaseLayout>
