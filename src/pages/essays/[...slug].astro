---
import { getCollection, render } from 'astro:content';
import EssayLayout from '../../layouts/EssayLayout.astro';

export async function getStaticPaths() {
  const essays = await getCollection('essays', ({ data }) => !data.draft);
  return essays.map((essay) => ({
    params: { slug: essay.id },
    props: { essay },
  }));
}

const { essay } = Astro.props;
const { Content } = await render(essay);
---

<EssayLayout
  title={essay.data.title}
  description={essay.data.description}
  pubDate={essay.data.pubDate}
  readTime={essay.data.readTime}
  category={essay.data.category}
  heroImage={essay.data.heroImage}
  heroAlt={essay.data.heroAlt}
>
  <Content />
</EssayLayout>
