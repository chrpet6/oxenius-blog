---
import BaseLayout from './BaseLayout.astro';
import CopyPageButton from '../components/CopyPageButton.astro';

interface Props {
  title: string;
  source: string;
  type: 'Podcast' | 'YouTube' | 'LinkedIn' | 'X';
  href: string;
  date: Date;
  image?: string;
}

const { title, source, type, href, date, image } = Astro.props;

const pageUrl = Astro.url.href;
const pathname = Astro.url.pathname.replace(/\/$/, '');
const markdownUrl = `${pathname}.md`;

const TYPE_ILLUSTRATIONS: Record<string, string> = {
  YouTube: '/illustration-youtube-video.png',
  Podcast: '/illustration-podcast-episode.png',
  LinkedIn: '/illustration-linkedin-post.png',
  X: '/illustration-x%20post.png',
};

const thumbnail: string | null = image ?? TYPE_ILLUSTRATIONS[type] ?? null;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const externalLabel =
  type === 'YouTube' ? 'Watch on YouTube'
  : type === 'Podcast' ? 'Listen to the episode'
  : type === 'LinkedIn' ? 'Read on LinkedIn'
  : 'Read on X';
---

<BaseLayout
  title={`${title} — Bookmarks`}
  description={`${source} · ${formattedDate}`}
>
  <article class="essay bookmark">
    <header class="essay-header">
      <nav class="essay-breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/bookmarks">Bookmarks</a>
      </nav>
      <h1 class="essay-title">{title}</h1>
      <p class="bookmark-byline">
        <span>{source}</span>
        <span aria-hidden="true">·</span>
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </p>
    </header>

    {thumbnail && (
      <div class="essay-hero bookmark-hero">
        <img src={thumbnail} alt="" loading="eager" />
      </div>
    )}

    <div class="bookmark-cta">
      <a class="bookmark-cta-link" href={href} target="_blank" rel="noopener">
        {externalLabel}
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 3h6v6"/>
          <path d="M11 3l-7 7"/>
        </svg>
      </a>
      <CopyPageButton pageUrl={pageUrl} markdownUrl={markdownUrl} />
    </div>

    <div class="essay-body">
      <slot />
    </div>
  </article>
</BaseLayout>
